# DeepSeek configuration.
# Server-side only. Never expose DEEPSEEK_API_KEY through Vite client env vars.
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=8000
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# career-ops integration. Leave blank to use the bundled git submodule.
CAREER_OPS_PATH=
CAREER_OPS_LANGUAGE=en

# App / local API.
APP_BASE_URL=http://localhost:5173
API_PORT=8787

# Supabase / Postgres. Required before database-backed phases can run.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Future product integrations.
RESEND_API_KEY=
SENTRY_DSN=
POSTHOG_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
