# DeepSeek configuration.
# Server-side only. Never expose DEEPSEEK_API_KEY through Vite client env vars.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=8000

# App / local API.
APP_BASE_URL=http://localhost:5173
API_PORT=8787

# Supabase / Postgres. Required before database-backed phases can run.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Future product integrations.
RESEND_API_KEY=
SENTRY_DSN=
POSTHOG_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
